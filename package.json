    "test": "vitest run",
    "postinstall": "node ./scripts/postinstall-config-examples.js"
  },
  "keywords": [
    "copilot",
    "github",
    "cli",
    "openspec",
    "agents"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eonio-dev/os-agents.git"
  },
  "homepage": "https://github.com/eonio-dev/os-agents#readme",
  "bugs": {
    "url": "https://github.com/eonio-dev/os-agents/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@github/copilot-sdk": "^1.0.0-beta.8",
    "commander": "^14.0.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
