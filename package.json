{
  "name": "@eonio-dev/os-agents",
  "version": "0.1.4",
  "description": "OS Agents: PRD-first Hans orchestrator for OpenSpec delivery with the GitHub Copilot SDK.",
  "type": "module",
  "files": [
    "dist",
    "scripts",
    "os-agents.config-example.json",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "os-agents": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
